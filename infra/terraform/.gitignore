# Terraform state (contains secrets — never commit)
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files with real values
terraform.tfvars
*.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive output
terraform.tfplan
*.plan
